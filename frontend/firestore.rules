rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ── Helper functions ───────────────────────────────────────
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }

    function isValidUser() {
      return isSignedIn()
        && request.resource.data.keys().hasAll(["id", "name", "email", "plan"])
        && request.resource.data.id == request.auth.uid
        && request.resource.data.email == request.auth.token.email;
    }

    // ── Users ──────────────────────────────────────────────────
    // Only the user themselves can read/write their own profile.
    match /users/{userId} {
      allow read:   if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser();
      allow update: if isOwner(userId)
        // Prevent changing immutable fields
        && request.resource.data.id == resource.data.id
        && request.resource.data.email == resource.data.email;
      allow delete: if isOwner(userId);
    }

    // ── Documents (uploaded PDFs / notes) ─────────────────────
    match /documents/{docId} {
      allow read, delete: if isSignedIn()
        && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.user_id == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.user_id == request.auth.uid
        // user_id is immutable after creation
        && request.resource.data.user_id == resource.data.user_id;
    }

    // ── Tutor sessions ─────────────────────────────────────────
    match /tutor_sessions/{sessionId} {
      allow read, delete: if isSignedIn()
        && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.user_id == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id;
    }

    // ── Oral exam sessions ─────────────────────────────────────
    match /oral_exams/{examId} {
      allow read, delete: if isSignedIn()
        && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.user_id == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id;
    }

    // ── Flashcard decks ────────────────────────────────────────
    match /flashcard_sets/{setId} {
      allow read, delete: if isSignedIn()
        && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.user_id == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id;
    }

    // ── Quiz attempts ──────────────────────────────────────────
    match /quiz_attempts/{attemptId} {
      allow read, delete: if isSignedIn()
        && resource.data.user_id == request.auth.uid;
      allow create: if isSignedIn()
        && request.resource.data.user_id == request.auth.uid;
      allow update: if isSignedIn()
        && resource.data.user_id == request.auth.uid
        && request.resource.data.user_id == resource.data.user_id;
    }

    // ── User preferences ───────────────────────────────────────
    match /preferences/{userId} {
      allow read, write: if isOwner(userId);
    }

    // ── Deny everything else ───────────────────────────────────
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
